// Use this configuration on a Mac.
// Mounts the docker socker to the container.
{
	"name": "bb-ripper dev container",
	
	"image": "ghcr.io/jvrck/noble-full",

	"mounts": [
        "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
    ],
    
    "privileged": true
}
